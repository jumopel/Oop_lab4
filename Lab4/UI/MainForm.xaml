<Window x:Class="Lab4.UI.MainForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Програма: Концерт" Height="450" Width="600" WindowStartupLocation="CenterScreen" Closing="Window_Closing">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Назва фірми-організатора:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtOrganizer" Padding="5"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Дата концерту:" FontWeight="Bold" Margin="0,0,0,5"/>
            <DatePicker x:Name="dtpDate" Padding="5"/>
        </StackPanel>

        <GroupBox Grid.Row="2" Header="Список виступів" Margin="0,5">
            <ListBox x:Name="lstPerformances" SelectionChanged="lstPerformances_SelectionChanged"/>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock x:Name="txtShortInfo" Text="Загальна тривалість: 0 хв" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray"/>
            <Button x:Name="btnAdd" Content="Додати" Width="100" Height="30" Margin="5" Click="btnAdd_Click"/>
            <Button x:Name="btnEdit" Content="Редагувати" Width="100" Height="30" Margin="5" Click="btnEdit_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>