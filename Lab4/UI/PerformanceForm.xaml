<Window x:Class="Lab4.UI.PerformanceForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Дані про виступ" Height="380" Width="400" WindowStartupLocation="CenterOwner" Closing="Window_Closing">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Назва твору:" FontWeight="Bold"/>
            <TextBox x:Name="txtTitle" Margin="0,5,0,15" Padding="3"/>

            <TextBlock Text="Тип твору:" FontWeight="Bold"/>
            <ComboBox x:Name="cmbWorkType" Margin="0,5,0,15" Padding="3"/>

            <TextBlock Text="Тривалість (хвилини):" FontWeight="Bold"/>
            <TextBox x:Name="txtDuration" Margin="0,5,0,15" Padding="3"/>

            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,20">
                <DockPanel>
                    <TextBlock Text="Виконавець:" VerticalAlignment="Center"/>
                    <Button x:Name="btnSelectPerformer" Content="Змінити..." HorizontalAlignment="Right" Width="80" Click="btnSelectPerformer_Click"/>
                    <TextBlock x:Name="txtPerformerName" Text="Не вказано" Margin="10,0" VerticalAlignment="Center" FontStyle="Italic" Foreground="DarkBlue"/>
                </DockPanel>
            </Border>

            <UniformGrid Columns="2">
                <Button x:Name="btnSave" Content="Зберегти" Height="35" Margin="5" Click="btnSave_Click" IsDefault="True"/>
                <Button x:Name="btnCancel" Content="Скасувати" Height="35" Margin="5" Click="btnCancel_Click" IsCancel="True"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>