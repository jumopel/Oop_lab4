<Window x:Class="Lab4.UI.PerformerForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Виконавець" Height="220" Width="300" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Ім'я:" FontWeight="Bold"/>
            <TextBox x:Name="txtFirstName" Margin="0,5,0,15" Padding="3"/>

            <TextBlock Text="Прізвище:" FontWeight="Bold"/>
            <TextBox x:Name="txtLastName" Margin="0,5,0,15" Padding="3"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="btnOk" Content="Зберегти" Width="80" Height="30" Margin="5" Click="btnOk_Click" IsDefault="True"/>
                <Button x:Name="btnCancel" Content="Скасувати" Width="80" Height="30" Margin="5" Click="btnCancel_Click" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>